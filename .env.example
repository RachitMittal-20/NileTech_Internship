# ─────────────────────────────────────────────────────────────────────────
# Strong Path Diagnostics — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────

# --- Supabase -----------------------------------------------------------
# Project URL and public/anon key, safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service role key — full database access, bypasses RLS.
# Used in server actions / route handlers only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) ---------------------------------------
# Used for auth emails, results notifications, and client/admin invites.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- App -------------------------------------------------------------
# Public base URL of this deployment, used to build absolute links in emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000
