# ─────────────────────────────────────────────────────────────────────────
# Strong Path Diagnostics — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────

# --- Supabase -----------------------------------------------------------
# Project URL and public/anon key, safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service role key — full database access, bypasses RLS.
# Used in server actions / route handlers only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) ---------------------------------------
# Used for auth emails, results notifications, and client/admin invites.
RESEND_API_KEY=
# Optional — defaults to Resend's shared sandbox sender (onboarding@resend.dev)
# if unset, which works with any Resend account with no domain verification
# needed. Set this to a verified sender on your own domain for production.
RESEND_FROM_EMAIL=

# --- App -------------------------------------------------------------
# Public base URL of this deployment, used to build absolute links in emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cron (Vercel Cron) --------------------------------------------------
# Required. Vercel signs cron-triggered requests with this as a bearer token
# (Authorization: Bearer <CRON_SECRET>) — app/api/cron/appointment-reminders
# rejects any request that doesn't match it. Generate a random value, e.g.:
#   openssl rand -hex 32
CRON_SECRET=
